        case(
          when(is_null(${media_single_data.campaign_name}), "Organic"),
          when(contains(${media_single_data.campaign_name}, "จ่ายจบ"), "จ่ายจบ"),
          when(contains(${media_single_data.campaign_name}, "dr."), "Doctor"),
          when(contains(${media_single_data.campaign_name}, "พามั่น"), "Emma พามั่น"),
          when(contains(${media_single_data.campaign_name}, "branch"), "สาขา"),
